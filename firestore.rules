rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Relaxed verification check for compatibility
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'akshari1823@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 2. Resource-specific helpers
    function isTeacher(schoolId) {
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function isStudent(schoolId) {
      return isSignedIn() && exists(/databases/$(database)/documents/students/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/students/$(request.auth.uid)).data.schoolId == schoolId;
    }

    // 3. Validation Blueprints
    function isValidSchool(data) {
      return data.keys().hasAll(['name', 'subscriptionTier']) && 
             data.keys().size() >= 2 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidTeacher(data) {
      return data.keys().hasAll(['schoolId', 'name', 'email', 'isAdmin']) &&
             data.schoolId is string && isValidId(data.schoolId) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.isAdmin is bool;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['schoolId', 'classId', 'name', 'status']) &&
             data.schoolId is string && isValidId(data.schoolId) &&
             data.classId is string &&
             data.name is string && data.name.size() <= 100;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['schoolId', 'studentId', 'date', 'status']) &&
             data.schoolId is string && isValidId(data.schoolId) &&
             data.studentId is string && isValidId(data.studentId) &&
             data.date is string &&
             data.status in ['PRESENT', 'ABSENT', 'LEAVE'];
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['schoolId', 'studentId', 'name', 'status']) &&
             data.studentId is string && isValidId(data.studentId) &&
             data.name is string && data.name.size() <= 200 &&
             data.status in ['PENDING', 'COMPLETED'];
    }

    // 4. Match Blocks
    
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSchool(incoming());
      allow update: if isAdmin() && isValidSchool(incoming());
    }

    match /teachers/{teacherId} {
      allow read: if isSignedIn() && (request.auth.uid == teacherId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == teacherId && isValidTeacher(incoming());
      allow update: if isSignedIn() && request.auth.uid == teacherId && isValidTeacher(incoming());
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStudent(incoming());
      allow update: if isSignedIn() && isValidStudent(incoming());
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAttendance(incoming());
      allow update: if isSignedIn() && isValidAttendance(incoming());
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidActivity(incoming());
      allow update: if isSignedIn() && isValidActivity(incoming());
    }

    match /skills/{skillId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /skillRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
    }
  }
}
